				},
				"isFeatured": {
					"type": "boolean",
					"description": "Đánh dấu sản phẩm nổi bật"
				},
				"material": {
					"type": "string",
					"description": "Chất liệu sản phẩm"
				},
				"images": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "Định danh hình ảnh"
							},
							"imageUrl": {
								"type": "string",
								"description": "Đường dẫn đến hình ảnh"
							},
							"altText": {
								"type": "string",
								"description": "Văn bản thay thế cho hình ảnh"
							},
							"displayOrder": {
								"type": "integer",
								"description": "Thứ tự hiển thị hình ảnh"
							},
							"isPrimary": {
								"type": "boolean",
								"description": "Cờ đánh dấu hình ảnh chính"
							}
						}
					},
					"description": "Hình ảnh sản phẩm"
				},
				"origin": {
					"type": "string",
					"description": "Xuất xứ sản phẩm"
				},
				"warrantyInfo": {
					"type": "string",
					"description": "Thông tin bảo hành"
				},
				"ratingAvg": {
					"type": "number",
					"description": "Điểm đánh giá trung bình"
				},
				"ratingCount": {
					"type": "integer",
					"description": "Số lượng đánh giá"
				},
				"displayPrice": {
					"type": "number",
					"description": "Giá hiển thị (giá khuyến mãi hoặc giá gốc)"
				},
				"discountPercentage": {
					"type": "number",
					"description": "Phần trăm giảm giá nếu có khuyến mãi"
				},
				"primaryImage": {
					"type": "string",
					"description": "URL đến hình ảnh chính"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"name",
				"slug",
				"price"
			]
		},
		"ProductVariant": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"productId": {
					"type": "string",
					"description": "Tham chiếu đến sản phẩm chính"
				},
				"name": {
					"type": "string",
					"description": "Tên biến thể (ví dụ: 'Đỏ / XL')"
				},
				"sku": {
					"type": "string",
					"description": "Mã quản lý kho cho biến thể"
				},
				"price": {
					"type": "number",
					"description": "Giá biến thể"
				},
				"stockQuantity": {
					"type": "integer",
					"description": "Số lượng tồn kho"
				},
				"color": {
					"type": "string",
					"description": "Thuộc tính màu sắc"
				},
				"size": {
					"type": "string",
					"description": "Thuộc tính kích thước"
				},
				"weight": {
					"type": "number",
					"description": "Trọng lượng tính bằng gram"
				},
				"isActive": {
					"type": "boolean",
					"description": "Trạng thái hoạt động của biến thể"
				},
				"imageUrl": {
					"type": "string",
					"description": "URL đến ảnh biến thể"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"productId",
				"name",
				"sku"
			]
		},
		"User": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"username": {
					"type": "string",
					"description": "Tên đăng nhập người dùng"
				},
				"email": {
					"type": "string",
					"format": "email",
					"description": "Địa chỉ email người dùng"
				},
				"fullName": {
					"type": "string",
					"description": "Họ và tên người dùng"
				},
				"phoneNumber": {
					"type": "string",
					"description": "Số điện thoại người dùng"
				},
				"role": {
					"type": "string",
					"enum": [
						"customer",
						"admin",
						"staff"
					],
					"description": "Vai trò người dùng"
				},
				"isActive": {
					"type": "boolean",
					"description": "Trạng thái hoạt động của tài khoản"
				},
				"addresses": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "Định danh địa chỉ"
							},
							"receiverName": {
								"type": "string",
								"description": "Tên người nhận"
							},
							"phone": {
								"type": "string",
								"description": "Số điện thoại liên hệ giao hàng"
							},
							"addressLine": {
								"type": "string",
								"description": "Địa chỉ đường phố"
							},
							"ward": {
								"type": "string",
								"description": "Phường/Xã"
							},
							"district": {
								"type": "string",
								"description": "Quận/Huyện"
							},
							"city": {
								"type": "string",
								"description": "Thành phố/Tỉnh"
							},
							"isDefault": {
								"type": "boolean",
								"description": "Cờ đánh dấu địa chỉ mặc định"
							}
						}
					},
					"description": "Danh sách địa chỉ đã lưu của người dùng"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo tài khoản"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"username",
				"email"
			]
		},
		"Cart": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"userId": {
					"type": "string",
					"description": "ID người dùng sở hữu giỏ hàng"
				},
				"sessionId": {
					"type": "string",
					"description": "ID phiên cho người dùng chưa đăng nhập"
				},
				"subtotal": {
					"type": "number",
					"description": "Tổng giá trị sản phẩm trong giỏ hàng"
				},
				"shippingCost": {
					"type": "number",
					"description": "Chi phí vận chuyển"
				},
				"totalAmount": {
					"type": "number",
					"description": "Tổng tiền (subtotal + shippingCost)"
				},
				"itemCount": {
					"type": "integer",
					"description": "Số lượng sản phẩm trong giỏ hàng"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			}
		},
		"CartItem": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"cartId": {
					"type": "string",
					"description": "Tham chiếu đến giỏ hàng"
				},
				"productId": {
					"type": "string",
					"description": "Tham chiếu đến sản phẩm"
				},
				"variantId": {
					"type": "string",
					"description": "Tham chiếu đến biến thể sản phẩm (nếu có)"
				},
				"quantity": {
					"type": "integer",
					"description": "Số lượng sản phẩm"
				},
				"price": {
					"type": "number",
					"description": "Giá sản phẩm tại thời điểm thêm vào giỏ hàng"
				},
				"subtotal": {
					"type": "number",
					"description": "Tổng tiền (price * quantity)"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"cartId",
				"productId",
				"quantity",
				"price"
			]
		},
		"Discount": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"code": {
					"type": "string",
					"description": "Mã giảm giá duy nhất"
				},
				"name": {
					"type": "string",
					"description": "Tên chương trình giảm giá"
				},
				"discountType": {
					"type": "string",
					"enum": [
						"percentage",
						"fixedAmount"
					],
					"description": "Loại giảm giá: phần trăm hoặc số tiền cố định"
				},
				"discountValue": {
					"type": "number",
					"description": "Giá trị giảm giá: % hoặc số tiền"
				},
				"minPurchaseAmount": {
					"type": "number",
					"description": "Giá trị đơn hàng tối thiểu để áp dụng"
				},
				"maxDiscountAmount": {
					"type": "number",
					"description": "Số tiền giảm tối đa (áp dụng cho giảm giá phần trăm)"
				},
				"isActive": {
					"type": "boolean",
					"description": "Trạng thái kích hoạt của mã giảm giá"
				},
				"startDate": {
					"type": "string",
					"format": "date-time",
					"description": "Ngày bắt đầu hiệu lực"
				},
				"endDate": {
					"type": "string",
					"format": "date-time",
					"description": "Ngày kết thúc hiệu lực"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"code",
				"name",
				"discountType",
				"discountValue",
				"startDate"
			]
		},
		"Order": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"orderNumber": {
					"type": "string",
					"description": "Mã đơn hàng duy nhất"
				},
				"userId": {
					"type": "string",
					"description": "ID tham chiếu người dùng"
				},
				"status": {
					"type": "string",
					"enum": [
						"pending",
						"processing",
						"shipped",
						"delivered",
						"cancelled"
					],
					"description": "Trạng thái đơn hàng"
				},
				"paymentStatus": {
					"type": "string",
					"enum": [
						"pending",
						"paid",
						"failed",
						"refunded"
					],
					"description": "Trạng thái thanh toán"
				},
				"addressType": {
					"type": "string",
					"enum": [
						"user_saved",
						"manual"
					],
					"description": "Loại địa chỉ giao hàng"
				},
				"addressId": {
					"type": "string",
					"description": "Tham chiếu đến địa chỉ đã lưu (nếu dùng addressType là user_saved)"
				},
				"shippingAddress": {
					"type": "object",
					"properties": {
						"receiverName": {
							"type": "string"
						},
						"phone": {
							"type": "string"
						},
						"addressLine": {
							"type": "string"
						},
						"ward": {
							"type": "string"
						},
						"district": {
							"type": "string"
						},
						"city": {
							"type": "string"
						}
					},
					"description": "Địa chỉ giao hàng thủ công"
				},
				"subtotal": {
					"type": "number",
					"description": "Tổng tiền hàng"
				},
				"shippingCost": {
					"type": "number",
					"description": "Chi phí vận chuyển"
				},
				"shippingFeeWaived": {
					"type": "boolean",
					"description": "Miễn phí vận chuyển"
				},
				"taxAmount": {
					"type": "number",
					"description": "Tiền thuế"
				},
				"discountAmount": {
					"type": "number",
					"description": "Tiền giảm giá"
				},
				"totalAmount": {
					"type": "number",
					"description": "Tổng số tiền đơn hàng"
				},
				"paymentMethod": {
					"type": "string",
					"enum": [
						"cod",
						"bank_transfer",
						"momo",
						"zalopay",
						"vnpay"
					],
					"description": "Phương thức thanh toán"
				},
				"shippingMethod": {
					"type": "string",
					"enum": [
						"standard",
						"express",
						"same_day"
					],
					"description": "Phương thức vận chuyển"
				},
				"trackingNumber": {
					"type": "string",
					"description": "Mã theo dõi vận chuyển"
				},
				"discountId": {
					"type": "string",
					"description": "Tham chiếu mã giảm giá đã áp dụng"
				},
				"notes": {
					"type": "string",
					"description": "Ghi chú đơn hàng"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo đơn hàng"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"orderNumber",
				"userId",
				"status",
				"subtotal",
				"totalAmount"
			]
		},
		"OrderItem": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"orderId": {
					"type": "string",
					"description": "Tham chiếu đến đơn hàng"
				},
				"productId": {
					"type": "string",
					"description": "Tham chiếu đến sản phẩm"
				},
				"variantId": {
					"type": "string",
					"description": "Tham chiếu đến biến thể sản phẩm (nếu có)"
				},
				"productName": {
					"type": "string",
