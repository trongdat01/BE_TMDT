{
	"swagger": "2.0",
	"info": {
		"version": "1.0.0",
		"title": "Hệ thống API E-commerce",
		"description": "Tài liệu API cho hệ thống thương mại điện tử Node.js"
	},
	"host": "localhost:8888",
	"basePath": "/api",
	"schemes": [
		"http",
		"https"
	],
	"securityDefinitions": {
		"bearerAuth": {
			"type": "apiKey",
			"name": "Authorization",
			"in": "header",
			"description": "Header xác thực JWT sử dụng Bearer scheme. Ví dụ: 'Bearer {token}'"
		}
	},
	"definitions": {
		"Brand": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"name": {
					"type": "string",
					"description": "Tên thương hiệu"
				},
				"slug": {
					"type": "string",
					"description": "Tên thương hiệu thân thiện với URL"
				},
				"logoUrl": {
					"type": "string",
					"description": "URL của logo thương hiệu"
				},
				"description": {
					"type": "string",
					"description": "Mô tả thương hiệu"
				},
				"isDomestic": {
					"type": "boolean",
					"description": "Thương hiệu nội địa hay quốc tế"
				},
				"isActive": {
					"type": "boolean",
					"description": "Thương hiệu đang hoạt động hay đã bị xóa mềm"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"name",
				"slug"
			]
		},
		"Category": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"name": {
					"type": "string",
					"description": "Tên danh mục"
				},
				"slug": {
					"type": "string",
					"description": "Tên danh mục thân thiện với URL"
				},
				"description": {
					"type": "string",
					"description": "Mô tả danh mục"
				},
				"parentId": {
					"type": "string",
					"description": "ID danh mục cha"
				},
				"imageUrl": {
					"type": "string",
					"description": "URL hình ảnh danh mục"
				},
				"isActive": {
					"type": "boolean",
					"description": "Danh mục đang hoạt động hay không"
				},
				"displayOrder": {
					"type": "integer",
					"description": "Thứ tự hiển thị để sắp xếp"
				},
				"createdAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm tạo"
				},
				"updatedAt": {
					"type": "string",
					"format": "date-time",
					"description": "Thời điểm cập nhật cuối cùng"
				}
			},
			"required": [
				"name",
				"slug"
			]
		},
		"Product": {
			"type": "object",
			"properties": {
				"_id": {
					"type": "string",
					"description": "Định danh duy nhất"
				},
				"name": {
					"type": "string",
					"description": "Tên sản phẩm"
				},
				"slug": {
					"type": "string",
					"description": "Tên sản phẩm thân thiện với URL"
				},
				"description": {
					"type": "string",
					"description": "Mô tả sản phẩm"
				},
				"price": {
					"type": "number",
					"description": "Giá gốc sản phẩm"
				},
				"salePrice": {
					"type": "number",
					"description": "Giá khuyến mãi nếu có giảm giá"
				},
				"sku": {
					"type": "string",
					"description": "Mã quản lý kho"
				},
				"stockQuantity": {
					"type": "integer",
					"description": "Số lượng tồn kho"
				},
				"brandId": {
